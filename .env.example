# ──────────────────────────────────────────────
# FinSurfing — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────

# ── Core ──────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_to_a_long_random_string

# ── Database ──────────────────────────────────
# Postgres (optional — falls back to in-memory store)
DATABASE_URL=postgresql://user:password@host:5432/finsurfing

# ── QuestDB (time-series tick store) ──────────
# Railway: set to the internal URL of your QuestDB service
# Local dev: docker-compose provides questdb at http://localhost:9000
QUESTDB_URL=http://localhost:9000

# ── Python Quant Sidecar ──────────────────────
# Railway: set to the internal URL of your quant-sidecar service
# Local dev: docker-compose provides it at http://localhost:5001
QUANT_SIDECAR_URL=http://localhost:5001

# ── AI Providers ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── Market Data ──────────────────────────────
FINNHUB_API_KEY=
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVEDATA_API_KEY=
AISA_API_KEY=

# ── Optional per-user header overrides ────────
# Clients can also pass these as request headers (x-finnhub-key, etc.)
# Server uses env as fallback when headers are absent.
