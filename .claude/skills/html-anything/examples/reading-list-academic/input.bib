  url     = {https://dl.acm.org/doi/10.1145/3442188.3445922},
  keywords = {ethics, bias, large-language-models},
  abstract = {We outline a set of concerns about the increasing size of language models, including environmental and financial costs, the difficulty of curating massive training data, the entrenching of dominant viewpoints, and the risk of producing seemingly coherent outputs that obscure their origins.},
}

