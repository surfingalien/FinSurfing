From b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1 Mon Sep 17 00:00:00 2026
From: Mira Park <mira@clockless.ai>
Date: Mon, 4 May 2026 11:42:08 -0700
Subject: [PATCH 2/3] checkout: webhook drains pendingChargeQueue on
 charge.succeeded / charge.failed

Pairs with the previous commit. The webhook handler now reads the
pendingCharges row, transitions the order's payment_state, and
deletes the row.
---
 src/checkout/webhook.ts        | 22 +++++++++++++++++++++-
 tests/checkout/webhook.test.ts | 28 ++++++++++++++++++++++++++++
 2 files changed, 49 insertions(+), 1 deletion(-)

diff --git a/src/checkout/webhook.ts b/src/checkout/webhook.ts
index 6666666..7777777 100644
--- a/src/checkout/webhook.ts
+++ b/src/checkout/webhook.ts
@@ -1,15 +1,35 @@
 import type { Request, Response } from "express"
 import { db } from "../db"
+import { logger } from "../obs/logger"

 export async function paymentWebhook(req: Request, res: Response) {
   const event = req.body as { type: string; data: { chargeId: string } }
   if (event.type === "charge.succeeded") {
+    const pending = await db.pendingCharges.findByChargeId(event.data.chargeId)
+    if (pending) {
+      await db.orders.update(pending.order_id, { payment_state: "paid" })
+      await db.pendingCharges.deleteByChargeId(event.data.chargeId)
+      logger.info({ orderId: pending.order_id }, "drained pending charge: paid")
+    }
     return res.status(200).end()
   }
+  if (event.type === "charge.failed") {
+    const pending = await db.pendingCharges.findByChargeId(event.data.chargeId)
+    if (pending) {
+      await db.orders.update(pending.order_id, { payment_state: "failed" })
+      await db.pendingCharges.deleteByChargeId(event.data.chargeId)
+      logger.warn({ orderId: pending.order_id }, "drained pending charge: failed")
+    }
+    return res.status(200).end()
+  }
   return res.status(204).end()
 }
diff --git a/tests/checkout/webhook.test.ts b/tests/checkout/webhook.test.ts
index 8888888..9999999 100644
--- a/tests/checkout/webhook.test.ts
+++ b/tests/checkout/webhook.test.ts
@@ -1,8 +1,36 @@
 import { describe, it, expect, vi } from "vitest"
 import { paymentWebhook } from "../../src/checkout/webhook"
 import { db } from "../../src/db"

 describe("paymentWebhook", () => {
   it("returns 204 for unknown event types", async () => {
     const res = mockRes()
     await paymentWebhook({ body: { type: "ping" } } as any, res)
     expect(res.statusCode).toBe(204)
   })
+
+  it("transitions the order to paid on charge.succeeded", async () => {
+    vi.spyOn(db.pendingCharges, "findByChargeId").mockResolvedValue({ order_id: "o_1", charge_id: "ch_1" } as any)
+    const updateSpy = vi.spyOn(db.orders, "update").mockResolvedValue(undefined as any)
+    const deleteSpy = vi.spyOn(db.pendingCharges, "deleteByChargeId").mockResolvedValue(undefined as any)
+    const res = mockRes()
+    await paymentWebhook({ body: { type: "charge.succeeded", data: { chargeId: "ch_1" } } } as any, res)
+    expect(updateSpy).toHaveBeenCalledWith("o_1", { payment_state: "paid" })
+    expect(deleteSpy).toHaveBeenCalledWith("ch_1")
+    expect(res.statusCode).toBe(200)
+  })
+
+  it("transitions the order to failed on charge.failed", async () => {
+    vi.spyOn(db.pendingCharges, "findByChargeId").mockResolvedValue({ order_id: "o_2", charge_id: "ch_2" } as any)
+    const updateSpy = vi.spyOn(db.orders, "update").mockResolvedValue(undefined as any)
+    vi.spyOn(db.pendingCharges, "deleteByChargeId").mockResolvedValue(undefined as any)
+    const res = mockRes()
+    await paymentWebhook({ body: { type: "charge.failed", data: { chargeId: "ch_2" } } } as any, res)
+    expect(updateSpy).toHaveBeenCalledWith("o_2", { payment_state: "failed" })
+    expect(res.statusCode).toBe(200)
+  })
 })

 function mockRes() {
   const res: any = { statusCode: 0 }
   res.status = (c: number) => { res.statusCode = c; return res }
   res.end = () => res
   res.json = () => res
   return res
 }
