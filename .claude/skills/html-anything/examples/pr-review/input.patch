+-- 0051_pending_charges
+-- Adds pending_charges table for charges awaiting external resolution.
+
+CREATE TABLE pending_charges (
+  id          BIGSERIAL PRIMARY KEY,
+  order_id    TEXT      NOT NULL,
+  charge_id   TEXT      NOT NULL UNIQUE,
+  status      TEXT      NOT NULL,
+  enqueued_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
+);
+
+CREATE INDEX idx_pending_charges_order_id ON pending_charges (order_id);
+CREATE INDEX idx_pending_charges_status   ON pending_charges (status);
+
