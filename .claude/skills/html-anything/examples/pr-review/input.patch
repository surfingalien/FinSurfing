From a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0 Mon Sep 17 00:00:00 2026
From: Mira Park <mira@clockless.ai>
Date: Mon, 4 May 2026 09:15:32 -0700
Subject: [PATCH 1/3] checkout: fail closed when payment provider returns
 ambiguous status

Previously a `pending_review` response from the payment provider was
treated as a successful charge by the order pipeline. That is unsafe
under provider-side fraud holds — we'd ship the order before the
charge resolved.

This change routes any non-`succeeded` status into the new
`pendingChargeQueue` and leaves the order in `awaiting_payment`.
The webhook handler is responsible for transitioning out.
---
 src/checkout/charge.ts          | 24 ++++++++++++++++--------
 src/checkout/pendingQueue.ts    | 18 ++++++++++++++++++
 tests/checkout/charge.test.ts   | 38 +++++++++++++++++++++++++++++---------
 3 files changed, 63 insertions(+), 17 deletions(-)
 create mode 100644 src/checkout/pendingQueue.ts

diff --git a/src/checkout/charge.ts b/src/checkout/charge.ts
index 1111111..2222222 100644
--- a/src/checkout/charge.ts
+++ b/src/checkout/charge.ts
@@ -1,18 +1,24 @@
 import type { Order } from "../order/types"
 import { provider } from "../payments/provider"
+import { enqueuePendingCharge } from "./pendingQueue"
 import { logger } from "../obs/logger"

 export async function chargeOrder(order: Order) {
   const result = await provider.charge({
     orderId: order.id,
     amountCents: order.totalCents,
     currency: order.currency,
   })
-  if (result.status === "succeeded") {
-    return { ok: true as const, chargeId: result.id }
-  }
-  logger.warn({ orderId: order.id, status: result.status }, "charge failed")
-  return { ok: false as const, reason: result.status }
+  if (result.status === "succeeded") {
+    return { ok: true as const, chargeId: result.id }
+  }
+  if (result.status === "pending_review" || result.status === "requires_action") {
+    logger.info({ orderId: order.id, status: result.status }, "charge pending — queued")
+    await enqueuePendingCharge(order.id, result.id)
+    return { ok: false as const, reason: "pending", chargeId: result.id }
+  }
+  logger.warn({ orderId: order.id, status: result.status }, "charge failed")
+  return { ok: false as const, reason: result.status }
 }
diff --git a/src/checkout/pendingQueue.ts b/src/checkout/pendingQueue.ts
new file mode 100644
index 0000000..3333333
--- /dev/null
+++ b/src/checkout/pendingQueue.ts
@@ -0,0 +1,18 @@
+import { db } from "../db"
+import { logger } from "../obs/logger"
+
+/**
+ * Records that a charge is awaiting external resolution. The webhook
+ * handler in `src/checkout/webhook.ts` reads from this table and
+ * transitions the order on `charge.succeeded` / `charge.failed`.
+ */
+export async function enqueuePendingCharge(orderId: string, chargeId: string) {
+  await db.pendingCharges.insert({
+    order_id: orderId,
+    charge_id: chargeId,
+    enqueued_at: new Date().toISOString(),
+    status: "awaiting_webhook",
+  })
+  logger.info({ orderId, chargeId }, "enqueued pending charge")
+}
+
diff --git a/tests/checkout/charge.test.ts b/tests/checkout/charge.test.ts
index 4444444..5555555 100644
--- a/tests/checkout/charge.test.ts
+++ b/tests/checkout/charge.test.ts
@@ -1,16 +1,38 @@
 import { describe, it, expect, vi } from "vitest"
 import { chargeOrder } from "../../src/checkout/charge"
 import { provider } from "../../src/payments/provider"
+import * as pendingQueue from "../../src/checkout/pendingQueue"

 describe("chargeOrder", () => {
   it("returns ok for a succeeded charge", async () => {
     vi.spyOn(provider, "charge").mockResolvedValue({ status: "succeeded", id: "ch_001" })
     const result = await chargeOrder({ id: "o_1", totalCents: 1200, currency: "USD" } as any)
     expect(result).toEqual({ ok: true, chargeId: "ch_001" })
   })

-  it("returns the failure reason for a failed charge", async () => {
-    vi.spyOn(provider, "charge").mockResolvedValue({ status: "card_declined", id: "ch_002" })
-    const result = await chargeOrder({ id: "o_2", totalCents: 800, currency: "USD" } as any)
-    expect(result).toEqual({ ok: false, reason: "card_declined" })
-  })
+  it("returns the failure reason for a hard-declined charge", async () => {
+    vi.spyOn(provider, "charge").mockResolvedValue({ status: "card_declined", id: "ch_002" })
+    const result = await chargeOrder({ id: "o_2", totalCents: 800, currency: "USD" } as any)
+    expect(result).toEqual({ ok: false, reason: "card_declined" })
+  })
+
+  it("queues the charge and returns pending for a pending_review status", async () => {
+    vi.spyOn(provider, "charge").mockResolvedValue({ status: "pending_review", id: "ch_003" })
+    const enqueueSpy = vi.spyOn(pendingQueue, "enqueuePendingCharge").mockResolvedValue(undefined as any)
+    const result = await chargeOrder({ id: "o_3", totalCents: 5400, currency: "USD" } as any)
+    expect(result).toEqual({ ok: false, reason: "pending", chargeId: "ch_003" })
+    expect(enqueueSpy).toHaveBeenCalledWith("o_3", "ch_003")
+  })
+
+  it("queues the charge for a requires_action status", async () => {
+    vi.spyOn(provider, "charge").mockResolvedValue({ status: "requires_action", id: "ch_004" })
+    const enqueueSpy = vi.spyOn(pendingQueue, "enqueuePendingCharge").mockResolvedValue(undefined as any)
+    const result = await chargeOrder({ id: "o_4", totalCents: 1500, currency: "USD" } as any)
+    expect(result.ok).toBe(false)
+    expect(result.reason).toBe("pending")
+    expect(enqueueSpy).toHaveBeenCalled()
+  })
 })
